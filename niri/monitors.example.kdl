output "Virtual-1" {
    mode "1920x1080@60"
    scale 1
    position x=0 y=0
}

output "DP-5" {
    mode "2560x1440@180"
    scale 1
    position x=0 y=0
}

output "DP-6" {
    mode "2560x1440@180"
    scale 1
    position x=2560 y=0
}
workspace "1" {
    open-on-output "DP-6"
}
workspace "2" {
    open-on-output "DP-5"
}
workspace "3" {
    open-on-output "DP-5"
}
workspace "4" {
    open-on-output "DP-6"
}
